# Local user outputs & captures (never commit a user's training data)
*.xlsx
!docs/examples/*.xlsx
msb_day_details*.json
msb_calendar_html*.json
msb_capture*.json
!docs/examples/demo_*.json
# Ignore user data inside captures/, but keep the folder (and its inner
# .gitignore) tracked so instructions referencing captures/*.json work on
# first checkout.
captures/*
!captures/.gitignore
out/
*.local.json

# Commercial reference spreadsheets live locally only, never in the public repo.
# Anchored to the repo root so docs/examples/ (our own demo) stays tracked.
/examples/
.claude/
